{
  "name": "octane11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web \"pnpm --filter @octane11/api dev\" \"pnpm --filter @octane11/web dev\"",
    "build": "pnpm --filter @octane11/shared build && pnpm --filter @octane11/api build && pnpm --filter @octane11/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @octane11/api test"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.27.0",
    "globals": "^16.1.0"
  }
}
